# DataHub OSS connection
DATAHUB_GMS_URL=http://localhost:8080
DATAHUB_GMS_TOKEN=

# Reflex configuration
REFLEX_LESSONS_DIR=./datasets
REFLEX_BACKTEST_HISTORY_DIR=./datasets/history
REFLEX_APPROVAL_REQUIRED=true
REFLEX_MAX_SIMILAR_ASSETS=10

# Integration test configuration (Step 3)
# Prefix used to isolate test URNs from real data (default: reflex-test)
REFLEX_TEST_PREFIX=reflex-test

# LLM configuration (optional — used for lesson extraction and control synthesis)
# REFLEX_LLM_MODE=deterministic
#   - "deterministic" (default): Template-based extraction, no network required.
#   - "api": Uses the configured LLM API. Requires REFLEX_LLM_API_KEY.
# REFLEX_LLM_API_KEY=
# REFLEX_LLM_API_BASE=https://api.openai.com/v1
# REFLEX_LLM_MODEL=gpt-4o
# REFLEX_LLM_TIMEOUT_SECONDS=60
# REFLEX_LLM_MAX_RETRIES=2

# Logging
REFLEX_LOG_LEVEL=INFO
